{
  "name": "@voice/wake-word",
  "version": "0.1.1",
  "description": "Wake-word engine interface, mock, and push-to-talk for the voice assistant platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "wake-word-mock-demo": "./dist/cli/mock-demo.js",
    "wake-word-ptt-demo": "./dist/cli/ptt-demo.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "demo": "node ./dist/cli/ptt-demo.js --mock-mic",
    "demo:mock": "node ./dist/cli/mock-demo.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "voice-assistant",
    "wake-word",
    "typescript",
    "porcupine",
    "desktop"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/voice-wake-word.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@voice/core-types": "file:../voice-core-types"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@eslint/js": "^9.28.0",
    "@voice/mic-capture": "file:../voice-mic-capture",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "@voice/core-types": "^0.1.0",
    "@voice/mic-capture": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@voice/core-types": {
      "optional": false
    },
    "@voice/mic-capture": {
      "optional": true
    }
  }
}
